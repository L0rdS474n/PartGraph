# PartGraph environment variables (example).
#
# Copy this file to `.env` and fill in real values. The `.env` file is
# git-ignored and must never be committed.
#
# NOTE: None of these variables are required for PR1 (the database fundament).
# They are consumed only by the optional TME.eu enrichment step (PR5). Leave
# them as placeholders until then.

# TME.eu developer API credentials (register a free account at
# https://developers.tme.eu). Used only when TME enrichment is enabled; data
# obtained via TME must carry the "powered by TME.eu Data" attribution.
TME_TOKEN=your-tme-token-here
TME_SECRET=your-tme-secret-here
